# Room TBA environment variables
#
# Quick start (local dev):
#   cp .env.example .env.local
#   Fill DATABASE_URL (staging) + ADMIN_PASSWORD from Supabase / Vercel / maintainer
#
# Files (all gitignored except this example):
#   .env          — optional shared base (some teams keep secrets here only)
#   .env.local    — local dev + E2E vars (Astro/Vite loads with .env)
#   .env.staging  — staging preview DB only (staging smoke, isolated staging work)
#
# Use Supabase **session pooler** URLs (*.pooler.supabase.com) for local dev.

# --- Staging / local dev (default for `bun dev` and Vercel Preview staging branch) ---
# Project ref: dqoepgnqtibemendjuqw
STAGING_DATABASE_URL=postgresql://postgres.dqoepgnqtibemendjuqw:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
STAGING_DB_HOST_SUFFIX=

# --- Production (Vercel main / room-tba.uplbtools.me — do not use for routine local dev) ---
# Project ref: ccdqtmscmnixjbynwdvb
PROD_DATABASE_URL=postgresql://postgres.ccdqtmscmnixjbynwdvb:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Local dev: set DATABASE_URL to STAGING_DATABASE_URL (see .env.local).
# Production deploys: Vercel sets DATABASE_URL to PROD_DATABASE_URL on main.

ADMIN_PASSWORD=
# Preferred signing secret for admin_session cookies (falls back to ADMIN_PASSWORD if unset).
ADMIN_SESSION_SECRET=

# Vercel ISR on-demand revalidation (32+ chars). Set in Production + Preview; optional locally.
# Must match bypassToken in astro.config.mjs. Admin writes send x-prerender-revalidate.
ISR_BYPASS_TOKEN=

# Supabase JS client (Settings → API). Staging keys for local dev; prod keys on main deploy.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# MapTiler vector/terrain tiles (Settings → API keys; restrict to your domains).
PUBLIC_MAPTILER_KEY=

# Cloudflare R2 image uploads (optional until /api/admin/upload is needed)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Notification gateway (Discord bot — optional until bot is deployed)
# NOTIFICATION_GATEWAY_URL=https://your-bot.herokuapp.com/notifications
# NOTIFICATION_INGRESS_SECRET=

# Resend — daily editor digest of pending proposals (#272). Optional; digest
# is skipped when unset. Vercel injects CRON_SECRET automatically in prod;
# set locally only to test /api/cron/proposal-digest by hand.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Room TBA <digest@uplbtools.me>"
# CRON_SECRET=

# AMIS import (scripts/import-amis-classes.ts) — copy bearer token from browser DevTools after AMIS login.
# Tokens expire in about an hour; paste fresh when running --fetch. Never commit real tokens.
# Fetch once with --fetch (while token is valid); later imports read data/amis-*-{termId}.json (gitignored).
# Refused in CI when CI=true (see docs/testing.md).
AMIS_BEARER_TOKEN=
AMIS_SESSION_ID=

# --- E2E / CI testing (mutating — separate Supabase project; never production) ---
# Project ref: yhzinxlakcewqjaqbbaj
E2E_DATABASE_URL=postgresql://postgres.yhzinxlakcewqjaqbbaj:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
E2E_DB_HOST_SUFFIX=
E2E_PUBLIC_SUPABASE_URL=
E2E_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
E2E_ADMIN_PASSWORD=
E2E_ADMIN_SESSION_SECRET=
STAGING_BASE_URL=https://staging.room-tba.uplbtools.me
