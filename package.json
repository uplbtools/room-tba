{
  "name": "astro-room",
  "type": "module",
  "version": "1.23.0",
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:debug": "astro dev --verbose",
    "build": "bash scripts/vercel-build-guard.sh && astro build",
    "check:vercel-env": "bash scripts/check-vercel-env.sh",
    "check:prod-branch": "bash scripts/check-production-branch.sh",
    "preview": "astro preview",
    "build:e2e": "ASTRO_E2E_NODE=1 bun run build",
    "preview:e2e": "bash scripts/preview-e2e.sh",
    "serve:e2e": "bash scripts/serve-e2e.sh",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "test": "bun test src/lib src/constants --path-ignore-patterns='**/*.store.test.ts'",
    "test:components": "vitest run",
    "test:integration": "bun test ./integration --preload integration/preload.ts --concurrency 1",
    "test:integration:live": "bash scripts/run-integration-preview.sh",
    "test:all": "bun test src/lib src/constants --path-ignore-patterns='**/*.store.test.ts' && bun run test:components && bun run test:integration",
    "e2e": "playwright test",
    "e2e:advisory": "playwright test -c playwright.advisory.config.ts",
    "e2e:staging": "playwright test -c playwright.staging.config.ts",
    "e2e:reset-db": "bun run scripts/e2e-reset-db.ts",
    "check:migrations": "bun run scripts/check-migrations.ts",
    "check:bundle": "bun run scripts/check-bundle-budget.ts",
    "generate:issue-test-matrix": "bun run scripts/generate-issue-test-matrix.ts /tmp/all-issues.json",
    "generate:test-inventory": "bun run scripts/generate-test-inventory.ts",
    "post:test-inventory-discord": "bun run scripts/post-test-inventory-discord.ts",
    "check:readme": "bun run scripts/check-readme-drift.ts",
    "install:agent-tooling": "bash scripts/install-agent-tooling.sh",
    "install:agent-plugins": "bash scripts/install-agent-plugins.sh",
    "install:shopped-skills": "bash scripts/install-shopped-skills.sh",
    "check:pwa-legal": "bun run scripts/check-pwa-legal-routes.ts",
    "seed:events": "bun src/seed-events.ts",
    "seed:aliases": "bun run scripts/seed-aliases.ts",
    "import:amis-classes": "bun run scripts/import-amis-classes.ts",
    "import:final-exams": "bun run scripts/import-final-exams.ts",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "^11.0.2",
    "@astrojs/svelte": "^9.0.1",
    "@astrojs/vercel": "^11.0.2",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@electric-sql/pglite": "^0.5.3",
    "@lucide/svelte": "^1.23.0",
    "@maplibre/maplibre-gl-directions": "^0.9.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.1",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "astro": "^7.0.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "es-toolkit": "^1.49.0",
    "maplibre-gl": "^5.24.0",
    "pg": "^8.22.0",
    "svelte": "^5.56.4",
    "svelte-maplibre": "^1.3.0",
    "three": "^0.185.0",
    "typescript": "^6.0.3",
    "which-pm-runs": "^2.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.14",
    "@types/maplibre-gl": "^1.14.0",
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.0",
    "@vite-pwa/astro": "^1.2.0",
    "@vitest/browser": "^4.1.9",
    "bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "semantic-release": "^25.0.5",
    "vitest": "^4.1.9"
  }
}
