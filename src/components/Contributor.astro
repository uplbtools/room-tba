---
import { divide } from "es-toolkit/compat";

interface Props {
  name: string;
  img_url?: string;
  gh_url?: string;
  img_alt?: string;
}
const { name, img_url, gh_url, img_alt } = Astro.props;
---

{
  gh_url ? (
    <a
      class="contributor-profile tooltip"
      href={gh_url ?? "about:blank"}
      target="_blank"
    >
      <img src={img_url ?? "/profile.svg"} alt={img_alt} title={name} />
    </a>
  ) : (
    <div class="contributor-profile tooltip">
      <img src={img_url ?? "/profile.svg"} alt={img_alt} title={name} />
    </div>
  )
}

<style>
  img {
    width: 2.5rem;
    aspect-ratio: 1/1;
    border: 1px solid #aaa;
    border-radius: 2rem;
  }
  .contributor-profile {
    display: flex;
    font-size: 0.875rem;
    gap: 0.5rem;
    align-items: center;
    font-weight: 600;
  }
  a[href] {
    text-decoration: none;
    &:hover {
      color: hsl(5, 53%, 32%);
    }
  }
</style>
