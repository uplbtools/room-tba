---
import Layout from "@layouts/Layout.astro";
import CopyLinkButton from "@ui/CopyLinkButton.svelte";

type Item = {
  href: string;
  label: string;
  description?: string;
  copyUrl?: string;
  copyLabel?: string;
};

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  heading: string;
  intro: string;
  items: Item[];
  structuredData?: Record<string, unknown>[];
};

const {
  title,
  description,
  canonicalPath,
  heading,
  intro,
  items,
  structuredData = [],
}: Props = Astro.props;
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  structuredData={structuredData}
>
  <main class="entity-index-page">
    <section class="entity-index-page__content">
      <h1>{heading}</h1>
      <p>{intro}</p>
      <ul>
        {
          items.map((item) => (
            <li>
              <div class="entity-index-page__item-main">
                <a href={item.href}>{item.label}</a>
                {item.description && (
                  <span class="entity-index-page__description">
                    {item.description}
                  </span>
                )}
              </div>
              {item.copyUrl && (
                <div class="entity-index-page__item-actions">
                  <CopyLinkButton
                    url={item.copyUrl}
                    ariaLabel={item.copyLabel ?? `Copy link to ${item.label}`}
                    successMessage="Link copied."
                    errorMessage={`Could not copy link for ${item.label}.`}
                    variant="index"
                    feedback="inline"
                    client:load
                  />
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>

<style>
  .entity-index-page {
    min-height: 100dvh;
    background: linear-gradient(180deg, #faf6f4 0%, #ffffff 22rem);
  }

  .entity-index-page__content {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    color: #1f1f1f;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.1;
  }

  p {
    margin: 0.75rem 0 1.5rem;
    max-width: 54rem;
    line-height: 1.6;
  }

  ul {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid #eadfda;
    border-radius: 0.875rem;
    background: white;
  }

  .entity-index-page__item-main {
    display: grid;
    gap: 0.125rem;
    min-width: 0;
  }

  .entity-index-page__item-actions {
    justify-self: end;
  }

  a {
    color: #7b1113;
    font-weight: 600;
    text-decoration: none;
  }

  .entity-index-page__description {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    li {
      grid-template-columns: 1fr;
    }

    .entity-index-page__item-actions {
      justify-self: stretch;
    }
  }
</style>
