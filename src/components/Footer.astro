---
import Contributor from "./Contributor.astro";
---

<footer>
  <div class="website-data">
    <div class="website-version">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-git-fork-icon lucide-git-fork"
        ><circle cx="12" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"
        ></circle><circle cx="18" cy="6" r="3"></circle><path
          d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"></path><path d="M12 12v3"
        ></path></svg
      >
      <div>v1.0.0</div>
    </div>
    <p class="data-updated">
      Data sourced from <strong>UPLB AMIS</strong>. Last updated: <strong
        >January 2026.</strong
      >
    </p>
  </div>
  <div class="contributor-infos">
    <h3>Contributors</h3>
    <div class="contributor-profiles">
      <Contributor
        name={"Simonee Ezekiel Mariquit"}
        gh_url="https://github.com/smmariquit"
        img_alt="Amogus"
        img_url="https://avatars.githubusercontent.com/u/137183321?v=4"
      />
      <Contributor
        name={"Ken Daniele Ramiscal"}
        gh_url="https://github.com/Kenramiscal1106"
        img_alt="Student in a blue background"
        img_url="https://avatars.githubusercontent.com/u/89060408?v=4"
      />
      <Contributor
        name={"Niño Anthony Marmeto"}
      />
      <Contributor
        name={"Rosh Almario"}
      />
    </div>
  </div>
</footer>

<style>
  .contributor-infos {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .contributor-profiles {
    display: flex;
    flex-wrap:wrap;
    gap: 0.5rem;
  }
  .data-updated {
    &:not(strong) {
      color: hsl(0, 0%, 40%);
    }
  }
  .website-version {
    display:flex;
    align-items: center;
    gap:.25rem;
  }
  .website-data {
    display:flex;
    align-items:center;
    gap:1rem;
    font-size: 0.875rem;

  }
  footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    h3 {
      font-size: 1.125rem;
      font-weight:600;
    }
  }
</style>
