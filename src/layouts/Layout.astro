---
import { pwaInfo } from "virtual:pwa-info";
import "../styles/font-face.css";
import Analytics from "@vercel/analytics/astro";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_TITLE,
  SITE_URL,
  absoluteUrl,
} from "@lib/site";

type StructuredData = Record<string, unknown>;

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  imagePath?: string;
  robots?: string;
  structuredData?: StructuredData[];
};

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonicalPath = "/",
  imagePath = "/socmed.png",
  robots = "index,follow",
  structuredData = [],
}: Props = Astro.props;

const canonicalUrl = absoluteUrl(canonicalPath);
const imageUrl = absoluteUrl(imagePath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta name="theme-color" content="#a30e00" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content="Room TBA" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={new URL(SITE_URL).hostname} />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    {
      structuredData.map((entry) => (
        <script type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      * {
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          sans-serif;
        font-variation-settings: "opsz" 14;
      }

      :root {
        --font-display: "Cormorant Garamond", serif;
      }

      button {
        all: unset;
      }
      button,
      a,
      input {
        outline: 2px solid transparent;
        outline-offset: 2px;

        &:focus-visible {
          outline-color: hsl(5, 53%, 32%);
        }
      }
    </style>
  </head>
  <body>
    <div id="app-loading-shell" class="app-loading-shell" role="status" aria-live="polite">
      <div class="app-loading-shell__card">
        <div class="app-loading-shell__spinner" aria-hidden="true"></div>
        <p class="app-loading-shell__message">Loading campus data…</p>
      </div>
    </div>
    <slot />
    <Analytics />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  .app-loading-shell {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: hsl(5, 22%, 96%);
  }

  .app-loading-shell__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    width: min(18rem, calc(100% - 2rem));
    padding: 1rem 1.125rem;
    border: 1.5px solid hsl(5, 10%, 68%);
    border-radius: 1rem;
    background: hsl(5, 20%, 97%);
    box-shadow:
      0 0 0 1px hsla(15, 8%, 20%, 0.16),
      0 2px 8px hsla(0, 0%, 0%, 0.14),
      0 8px 20px hsla(0, 0%, 0%, 0.18);
    color: hsl(0, 0%, 18%);
    text-align: center;
  }

  .app-loading-shell__spinner {
    width: 1.375rem;
    height: 1.375rem;
    border: 2px solid hsl(5, 20%, 82%);
    border-top-color: hsl(5, 53%, 32%);
    border-radius: 50%;
    animation: app-loading-shell-spin 0.75s linear infinite;
  }

  .app-loading-shell__message {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.35;
  }

  @keyframes app-loading-shell-spin {
    from {
      rotate: 0deg;
    }
    to {
      rotate: 360deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .app-loading-shell__spinner {
      animation: none;
      border-top-color: hsl(5, 53%, 32%);
      opacity: 0.85;
    }
  }

  @media only screen and (max-width: 600px) {
    .container {
      padding: 1rem;
    }
  }
</style>
