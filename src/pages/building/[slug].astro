---
import EntityPage from "../../components/seo/EntityPage.astro";
import { getBuildingSlug } from "../../lib/app-data";
import { getAllBuildings } from "../../lib/services/map-data-service";
import { getBuildingPageData } from "../../lib/services/ssg-service";
import {
  absoluteUrl,
  breadcrumbSchema,
  jsonLd,
  webpageSchema,
} from "../../lib/site";

export async function getStaticPaths() {
  const buildings = await getAllBuildings();

  return buildings.map((building) => ({
    params: { slug: getBuildingSlug(building) },
    props: { buildingName: building.buildingName },
  }));
}

const routeSlug = Astro.params.slug;
const buildingName =
  Astro.props.buildingName ??
  (routeSlug
    ? (await getAllBuildings()).find(
        (candidate) => getBuildingSlug(candidate) === routeSlug,
      )?.buildingName
    : undefined);

if (!buildingName) {
  throw new Error(`Building not found for slug: ${routeSlug}`);
}

const appData = await getBuildingPageData(buildingName);

if (appData === null) {
  throw new Error(`Building not found for slug: ${buildingName}`);
}
const { building, roomCount } = appData;
const canonicalPath = `/building/${getBuildingSlug(building)}/`;
const title = `${buildingName} | Building at UPLB | Room TBA`;
const description = `Find rooms in ${buildingName} at UPLB. Open the building view on Room TBA for room listings, map context, and directions.`;
const intro = `${buildingName} has ${roomCount} room${roomCount === 1 ? "" : "s"} listed in Room TBA. Open this page to jump straight into the building result view and browse the mapped rooms.`;

const facts = [
  `${roomCount} room${roomCount === 1 ? "" : "s"} listed in this building`,
  building.directions ? `Directions available for this building` : null,
].filter((fact): fact is string => Boolean(fact));

const structuredData = jsonLd(
  webpageSchema({ title, description, path: canonicalPath }),
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Buildings", path: "/building/" },
    { name: buildingName, path: canonicalPath },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "Place",
    name: buildingName,
    description: building.directions ?? description,
    url: absoluteUrl(canonicalPath),
    geo:
      building.lat !== null && building.lon !== null
        ? {
            "@type": "GeoCoordinates",
            latitude: building.lat,
            longitude: building.lon,
          }
        : undefined,
  },
);
---

<EntityPage
  title={title}
  description={description}
  {canonicalPath}
  heading={`${buildingName} at UPLB`}
  {intro}
  {facts}
  breadcrumbs={[
    { href: "/", label: "Home" },
    { href: "/building/", label: "Buildings" },
    { href: canonicalPath, label: buildingName },
  ]}
  structuredData={structuredData}
  initialSearch={{ category: "building", value: buildingName }}
/>
