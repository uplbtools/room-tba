---
import EntityIndexPage from "../../components/seo/EntityIndexPage.astro";
import { getBuildingSlug, loadAppData } from "../../lib/app-data";
import { breadcrumbSchema, jsonLd, webpageSchema } from "../../lib/site";

const { buildings, rooms } = await loadAppData();

const items = buildings
  .slice()
  .sort((a, b) => a.building_name.localeCompare(b.building_name))
  .map((building) => {
    const roomCount = rooms.filter(
      (room) => room.building?.name === building.building_name,
    ).length;

    return {
      href: `/building/${getBuildingSlug(building)}/`,
      label: building.building_name,
      description: `${roomCount} room${roomCount === 1 ? "" : "s"} listed${building.directions ? " · includes directions" : ""}`,
    };
  });

const title = "UPLB buildings | Room TBA";
const description =
  "Browse building pages on Room TBA to find UPLB rooms, map context, and available building directions.";
const structuredData = jsonLd(
  webpageSchema({ title, description, path: "/building/" }),
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Buildings", path: "/building/" },
  ]),
);
---

<EntityIndexPage
  title={title}
  description={description}
  canonicalPath="/building/"
  heading="UPLB building pages"
  intro="Browse crawlable building pages for Room TBA. Each page opens the building result view and lists the rooms mapped to that building."
  {items}
  structuredData={structuredData}
/>
