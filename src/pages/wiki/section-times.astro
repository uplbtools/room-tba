const timeBlocks = [
  { wf: "A", tth: "S", time: "7:00", windows: "7:00–8:00 or 7:00–8:30", wfMatch: 78.4, tthMatch: 86.8 },
  { wf: "B", tth: "T", time: "8:30 / 9:00", windows: "8:30–10:00 or 9:00–10:00", wfMatch: 81.0, tthMatch: 90.9 },
  { wf: "C", tth: "U", time: "10:00", windows: "10:00–11:00 or 10:00–11:30", wfMatch: 86.8, tthMatch: 95.5 },
  { wf: "D", tth: "V", time: "11:30 / 12:00", windows: "11:30–1:00 or 12:00–1:00", wfMatch: 87.3, tthMatch: 93.1 },
  { wf: "E", tth: "W", time: "1:00", windows: "1:00–2:00 or 1:00–2:30", wfMatch: 88.5, tthMatch: 93.1 },
  { wf: "F", tth: "X", time: "2:30 / 3:00", windows: "2:30–4:00 or 3:00–4:00", wfMatch: 91.9, tthMatch: 92.5 },
