                <td>{row.meaning}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 id="midyear-compounds">Cross-ladder compounds (CRS 1253)</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Section</th>
              <th scope="col">Letter bridge</th>
              <th scope="col">Note</th>
