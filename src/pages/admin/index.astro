---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getEntityCounts } from "../../lib/services/admin-service";

const counts = await getEntityCounts();

const entities = [
  { key: "rooms", label: "Rooms", href: "/admin/rooms" },
  { key: "buildings", label: "Buildings", href: "/admin/buildings" },
  { key: "colleges", label: "Colleges", href: "/admin/colleges" },
  { key: "divisions", label: "Divisions", href: "/admin/divisions" },
  { key: "dorms", label: "Dorms", href: "/admin/dorms" },
];
---

<AdminLayout title="Dashboard" active="dashboard">
  <div class="dash-grid">
    {entities.map((e) => (
      <a href={e.href} class="dash-card">
        <div class="count">{counts[e.key] ?? 0}</div>
        <div class="label">{e.label}</div>
      </a>
    ))}
  </div>

  <div class="card" style="margin-top: 1.5rem;">
    <h2>Quick Actions</h2>
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <a href="/admin/rooms" class="btn btn-primary">Manage Rooms</a>
      <a href="/admin/buildings" class="btn btn-secondary">Manage Buildings</a>
      <a href="/admin/dorms" class="btn btn-secondary">Manage Dorms</a>
    </div>
  </div>
</AdminLayout>
