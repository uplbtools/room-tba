---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAllRoomsAdmin, getAllBuildingsAdmin, getAllCollegesAdmin, getAllDivisionsAdmin } from "../../../lib/services/admin-service";

const rooms = await getAllRoomsAdmin();
const buildings = await getAllBuildingsAdmin();
const colleges = await getAllCollegesAdmin();
const divisions = await getAllDivisionsAdmin();

const buildingMap = new Map(buildings.map((b) => [b.id, b.buildingName]));
const collegeMap = new Map(colleges.map((c) => [c.id, c.collegeName]));
const divisionMap = new Map(divisions.map((d) => [d.id, d.divisionName]));
---

<AdminLayout title="Rooms" active="rooms">
  <div class="search-bar">
    <input type="text" id="room-search" placeholder="Search room code..." />
  </div>

  <div class="table-wrapper">
    <table id="room-table">
      <thead>
        <tr>
          <th>Room Code</th>
          <th>Building</th>
          <th>College</th>
          <th>Division</th>
          <th>Directions</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {rooms.map((room) => (
          <tr data-code={room.roomCode.toLowerCase()}>
            <td><strong>{room.roomCode}</strong></td>
            <td>{room.buildingId ? buildingMap.get(room.buildingId) ?? "—" : "—"}</td>
            <td>{room.collegeId ? collegeMap.get(room.collegeId) ?? "—" : "—"}</td>
            <td>{room.divisionId ? divisionMap.get(room.divisionId) ?? "—" : "—"}</td>
            <td>{room.directions ? `<span class="muted">${room.directions.slice(0, 60)}${room.directions.length > 60 ? "..." : ""}</span>` : "—"}</td>
            <td><a href={`/admin/rooms/${room.id}`} class="btn btn-secondary" style="padding: 0.25rem 0.625rem; font-size: 0.75rem;">Edit</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {rooms.length === 0 && <div class="empty-state">No rooms found.</div>}
</AdminLayout>

<script>
  const search = document.getElementById("room-search") as HTMLInputElement;
  const rows = document.querySelectorAll("#room-table tbody tr");
  search?.addEventListener("input", () => {
    const q = search.value.toLowerCase();
    rows.forEach((row) => {
      const code = (row as HTMLElement).dataset.code || "";
      (row as HTMLElement).style.display = code.includes(q) ? "" : "none";
    });
  });
</script>
