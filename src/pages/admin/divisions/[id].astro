---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getDivisionById } from "../../../lib/services/admin-service";

const { id } = Astro.params;
const divisionId = parseInt(id ?? "");
if (isNaN(divisionId)) {
  return Astro.redirect("/admin/divisions");
}

const division = await getDivisionById(divisionId);
if (!division) {
  return Astro.redirect("/admin/divisions");
}

const success = Astro.url.searchParams.get("success") === "1";
const error = Astro.url.searchParams.get("error");
---

<AdminLayout title={`Edit ${division.divisionName}`} active="divisions">
  {success && <div class="alert alert-success">Saved successfully.</div>}
  {error && <div class="alert alert-error">{error}</div>}

  <form id="division-form" class="card">
    <div class="form-group">
      <label for="divisionName">Division Name</label>
      <input type="text" id="divisionName" name="divisionName" value={division.divisionName} required />
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin/divisions" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</AdminLayout>

<script>
  const form = document.getElementById("division-form") as HTMLFormElement;
  const divisionId = window.location.pathname.split("/").pop();

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const payload = { divisionName: formData.get("divisionName") };

    try {
      const res = await fetch(`/api/admin/divisions/${divisionId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        window.location.search = "?success=1";
      } else {
        const data = await res.json().catch(() => ({ error: "Request failed" }));
        window.location.search = `?error=${encodeURIComponent(data.error || "Save failed")}`;
      }
    } catch {
      window.location.search = `?error=${encodeURIComponent("Network error")}`;
    }
  });
</script>
