---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAllDivisionsAdmin } from "../../../lib/services/admin-service";

const divisions = await getAllDivisionsAdmin();
---

<AdminLayout title="Divisions" active="divisions">
  <div class="search-bar">
    <input type="text" id="division-search" placeholder="Search division name..." />
  </div>

  <div class="table-wrapper">
    <table id="division-table">
      <thead>
        <tr>
          <th>Division Name</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {divisions.map((d) => (
          <tr data-name={d.divisionName.toLowerCase()}>
            <td><strong>{d.divisionName}</strong></td>
            <td><a href={`/admin/divisions/${d.id}`} class="btn btn-secondary" style="padding: 0.25rem 0.625rem; font-size: 0.75rem;">Edit</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {divisions.length === 0 && <div class="empty-state">No divisions found.</div>}
</AdminLayout>

<script>
  const search = document.getElementById("division-search") as HTMLInputElement;
  const rows = document.querySelectorAll("#division-table tbody tr");
  search?.addEventListener("input", () => {
    const q = search.value.toLowerCase();
    rows.forEach((row) => {
      const name = (row as HTMLElement).dataset.name || "";
      (row as HTMLElement).style.display = name.includes(q) ? "" : "none";
    });
  });
</script>
