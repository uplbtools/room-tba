---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getDormById } from "../../../lib/services/admin-service";

const { id } = Astro.params;
const dormId = parseInt(id ?? "");
if (isNaN(dormId)) {
  return Astro.redirect("/admin/dorms");
}

const dorm = await getDormById(dormId);
if (!dorm) {
  return Astro.redirect("/admin/dorms");
}

const success = Astro.url.searchParams.get("success") === "1";
const error = Astro.url.searchParams.get("error");
---

<AdminLayout title={`Edit ${dorm.dormName}`} active="dorms">
  {success && <div class="alert alert-success">Saved successfully.</div>}
  {error && <div class="alert alert-error">{error}</div>}

  <form id="dorm-form" class="card">
    <div class="form-group">
      <label for="dormName">Dorm Name</label>
      <input type="text" id="dormName" name="dormName" value={dorm.dormName} required />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="shortName">Short Name</label>
        <input type="text" id="shortName" name="shortName" value={dorm.shortName ?? ""} />
      </div>
      <div class="form-group">
        <label for="gender">Gender</label>
        <select id="gender" name="gender">
          <option value="Male" selected={dorm.gender === "Male"}>Male</option>
          <option value="Female" selected={dorm.gender === "Female"}>Female</option>
          <option value="Mixed" selected={dorm.gender === "Mixed"}>Mixed</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="lat">Latitude</label>
        <input type="number" id="lat" name="lat" value={dorm.lat ?? ""} step="any" />
      </div>
      <div class="form-group">
        <label for="lon">Longitude</label>
        <input type="number" id="lon" name="lon" value={dorm.lon ?? ""} step="any" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="capacity">Capacity</label>
        <input type="number" id="capacity" name="capacity" value={dorm.capacity ?? ""} />
      </div>
      <div class="form-group">
        <label for="priceRange">Price Range</label>
        <input type="text" id="priceRange" name="priceRange" value={dorm.priceRange ?? ""} />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="managingOffice">Managing Office</label>
        <input type="text" id="managingOffice" name="managingOffice" value={dorm.managingOffice ?? ""} />
      </div>
      <div class="form-group">
        <label for="contactEmail">Contact Email</label>
        <input type="email" id="contactEmail" name="contactEmail" value={dorm.contactEmail ?? ""} />
      </div>
    </div>

    <div class="form-group">
      <label for="facebookLink">Facebook Link</label>
      <input type="url" id="facebookLink" name="facebookLink" value={dorm.facebookLink ?? ""} />
    </div>

    <div class="form-group">
      <label for="osmLink">OSM Link</label>
      <input type="url" id="osmLink" name="osmLink" value={dorm.osmLink ?? ""} />
    </div>

    <div class="form-group">
      <label for="amenities">Amenities (comma-separated)</label>
      <input type="text" id="amenities" name="amenities" value={(dorm.amenities ?? []).join(", ")} />
    </div>

    <div class="form-group">
      <label for="contactPhone">Contact Phone (comma-separated)</label>
      <input type="text" id="contactPhone" name="contactPhone" value={(dorm.contactPhone ?? []).join(", ")} />
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" id="isUpManaged" name="isUpManaged" checked={dorm.isUpManaged} style="width: auto; margin-right: 0.5rem;" />
        UP Managed
      </label>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description">{dorm.description ?? ""}</textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin/dorms" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</AdminLayout>

<script>
  const form = document.getElementById("dorm-form") as HTMLFormElement;
  const dormId = window.location.pathname.split("/").pop();

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    const amenitiesStr = (formData.get("amenities") as string) || "";
    const phoneStr = (formData.get("contactPhone") as string) || "";

    const payload = {
      dormName: formData.get("dormName"),
      shortName: (formData.get("shortName") as string) || null,
      lat: formData.get("lat") ? Number(formData.get("lat")) : null,
      lon: formData.get("lon") ? Number(formData.get("lon")) : null,
      gender: formData.get("gender"),
      capacity: formData.get("capacity") ? Number(formData.get("capacity")) : null,
      managingOffice: (formData.get("managingOffice") as string) || null,
      contactEmail: (formData.get("contactEmail") as string) || null,
      amenities: amenitiesStr ? amenitiesStr.split(",").map((s) => s.trim()).filter(Boolean) : [],
      osmLink: (formData.get("osmLink") as string) || null,
      description: (formData.get("description") as string) || null,
      isUpManaged: formData.get("isUpManaged") === "on",
      priceRange: (formData.get("priceRange") as string) || null,
      contactPhone: phoneStr ? phoneStr.split(",").map((s) => s.trim()).filter(Boolean) : [],
      facebookLink: (formData.get("facebookLink") as string) || null,
    };

    try {
      const res = await fetch(`/api/admin/dorms/${dormId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        window.location.search = "?success=1";
      } else {
        const data = await res.json().catch(() => ({ error: "Request failed" }));
        window.location.search = `?error=${encodeURIComponent(data.error || "Save failed")}`;
      }
    } catch {
      window.location.search = `?error=${encodeURIComponent("Network error")}`;
    }
  });
</script>
