---
import Layout from "../../layouts/Layout.astro";

const title = "Admin Login | Room TBA";
const description = "Sign in to manage rooms, buildings, and other data.";
---

<Layout title={title} description={description} canonicalPath="/admin/login" robots="noindex,nofollow">
  <div class="login-wrapper">
    <div class="login-card">
      <h1>Room TBA Editor</h1>
      <p>Sign in to manage room data.</p>
      <form id="login-form" action="/api/admin/auth" method="POST">
        <label for="password">Admin Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" />
        <button type="submit">Sign In</button>
        <p id="error" class="error" hidden></p>
      </form>
      <div class="login-help">
        <p>Forgot the password? Contact the site administrator.</p>
        <p class="muted">If you're setting this up for the first time, make sure <code>ADMIN_PASSWORD</code> is configured on the server.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement;
  const errorEl = document.getElementById("error") as HTMLParagraphElement;

  const errorMessages: Record<number, string> = {
    400: "Please enter a password.",
    401: "Wrong password. Double-check it and try again. If you've forgotten it, contact the site administrator.",
    500: "The server isn't fully configured yet. Ask the developer to set the ADMIN_PASSWORD environment variable.",
  };

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.hidden = true;
    const formData = new FormData(form);
    try {
      const res = await fetch("/api/admin/auth", {
        method: "POST",
        body: formData,
      });
      if (res.ok) {
        window.location.href = "/admin";
      } else {
        const fallback = "Something went wrong. Please try again or contact the site administrator.";
        errorEl.textContent = errorMessages[res.status] ?? fallback;
        errorEl.hidden = false;
      }
    } catch {
      errorEl.textContent = "Network error — check your internet connection and try again.";
      errorEl.hidden = false;
    }
  });
</script>

<style>
  .login-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: #f5f5f5;
  }
  .login-card {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 360px;
  }
  h1 { font-size: 1.5rem; margin: 0 0 0.5rem; color: #a30e00; }
  p { color: #666; margin: 0 0 1.5rem; }
  label { display: block; font-size: 0.875rem; margin-bottom: 0.25rem; color: #333; }
  input {
    width: 100%;
    padding: 0.625rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    box-sizing: border-box;
  }
  input:focus { border-color: #a30e00; }
  button {
    width: 100%;
    margin-top: 1rem;
    padding: 0.625rem;
    background: #a30e00;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
  }
  button:hover { background: #8a0c00; }
  .error {
    color: #d32f2f;
    font-size: 0.8125rem;
    margin-top: 0.75rem;
    line-height: 1.4;
  }
  .login-help {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
  .login-help p {
    font-size: 0.75rem;
    margin: 0 0 0.5rem;
    color: #999;
  }
  .login-help .muted {
    color: #aaa;
  }
  .login-help code {
    background: #f0f0f0;
    padding: 0.125rem 0.25rem;
    border-radius: 3px;
    font-size: 0.75rem;
  }
</style>
