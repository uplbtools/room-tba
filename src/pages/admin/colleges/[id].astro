---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getCollegeById } from "../../../lib/services/admin-service";

const { id } = Astro.params;
const collegeId = parseInt(id ?? "");
if (isNaN(collegeId)) {
  return Astro.redirect("/admin/colleges");
}

const college = await getCollegeById(collegeId);
if (!college) {
  return Astro.redirect("/admin/colleges");
}

const success = Astro.url.searchParams.get("success") === "1";
const error = Astro.url.searchParams.get("error");
---

<AdminLayout title={`Edit ${college.collegeName}`} active="colleges">
  {success && <div class="alert alert-success">Saved successfully.</div>}
  {error && <div class="alert alert-error">{error}</div>}

  <form id="college-form" class="card">
    <div class="form-group">
      <label for="collegeName">College Name</label>
      <input type="text" id="collegeName" name="collegeName" value={college.collegeName} required />
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin/colleges" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</AdminLayout>

<script>
  const form = document.getElementById("college-form") as HTMLFormElement;
  const collegeId = window.location.pathname.split("/").pop();

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const payload = { collegeName: formData.get("collegeName") };

    try {
      const res = await fetch(`/api/admin/colleges/${collegeId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        window.location.search = "?success=1";
      } else {
        const data = await res.json().catch(() => ({ error: "Request failed" }));
        window.location.search = `?error=${encodeURIComponent(data.error || "Save failed")}`;
      }
    } catch {
      window.location.search = `?error=${encodeURIComponent("Network error")}`;
    }
  });
</script>
