---
import EntityPage from "../../components/seo/EntityPage.astro";
import { getDivisionSlug } from "../../lib/app-data";
import { getDivisionPageData } from "../../lib/services/ssg-service";
import { getAllDivisions } from "../../lib/services/map-data-service";
import {
  absoluteUrl,
  breadcrumbSchema,
  jsonLd,
  ogImageUrl,
  webpageSchema,
} from "../../lib/site";

export async function getStaticPaths() {
  const divisions = await getAllDivisions();

  return divisions.map((division) => ({
    params: { slug: getDivisionSlug(division) },
    props: { divisionName: division.divisionName },
  }));
}

const { divisionName } = Astro.props;
const appData = await getDivisionPageData(divisionName);

if (appData === null) {
  throw new Error(`Division not found for slug: ${divisionName}`);
}
const { division, roomCount } = appData;

const canonicalPath = `/division/${getDivisionSlug(division)}/`;
const title = `${division.divisionName} | Division at UPLB | Room TBA`;
const description = `Find rooms associated with ${division.divisionName} at UPLB. Open the division view on Room TBA to browse linked rooms.`;
const intro = `${division.divisionName} currently has ${roomCount} room${roomCount === 1 ? "" : "s"} listed in Room TBA. Open this page to jump straight into the division result view.`;

const facts = [
  `${roomCount} room${roomCount === 1 ? "" : "s"} linked to this division`,
];

const structuredData = jsonLd(
  webpageSchema({ title, description, path: canonicalPath }),
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Divisions", path: "/division/" },
    { name: division.divisionName, path: canonicalPath },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    name: division.divisionName,
    description,
    url: absoluteUrl(canonicalPath),
    image: ogImageUrl(),
    parentOrganization: {
      "@type": "CollegeOrUniversity",
      name: "University of the Philippines Los Banos",
    },
  },
);
---

<EntityPage
  title={title}
  description={description}
  {canonicalPath}
  heading={`${division.divisionName} at UPLB`}
  {intro}
  {facts}
  breadcrumbs={[
    { href: "/", label: "Home" },
    { href: "/division/", label: "Divisions" },
    { href: canonicalPath, label: division.divisionName },
  ]}
  structuredData={structuredData}
  initialSearch={{ category: "division", value: division.divisionName }}
/>
